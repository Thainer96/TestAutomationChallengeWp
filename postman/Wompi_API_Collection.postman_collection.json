					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{public_key}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount_in_cents\": 1500000,\n  \"currency\": \"COP\",\n  \"customer_email\": \"pepito_perez@example.com\",\n  \"reference\": \"{{reference}}\",\n  \"signature\": \"{{signature}}\",\n  \"acceptance_token\": \"{{acceptance_token}}\",\n  \"accept_personal_auth\": \"{{personal_auth_token}}\",\n  \"payment_method\": {\n    \"type\": \"NEQUI\",\n    \"phone_number\": \"3992222222\"\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/transactions",
							"host": ["{{base_url}}"],
							"path": ["transactions"]
						}
					}
				},
